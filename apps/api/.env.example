# === Banco ===
# DATABASE_URL  -> usada pelo runtime da API (PrismaClient)
# DIRECT_URL    -> usada só pelas migrações (prisma migrate). Ver schema.prisma.
#
# Dev local (Postgres embutido, sem pooler): as duas apontam para o mesmo banco.
DATABASE_URL=postgresql://studybetter:studybetter@localhost:5432/studybetter
DIRECT_URL=postgresql://studybetter:studybetter@localhost:5432/studybetter
#
# Produção (Supabase) — pegue em Project Settings > Database:
#   DATABASE_URL = Transaction pooler (Supavisor), porta 6543, com pgbouncer=true.
#     connection_limit=8: a API é um processo persistente (não serverless), então um
#     pool maior que 1 destrava a concorrência das requests.
#     postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=8
#   DIRECT_URL   = Direct connection (Session), porta 5432
#     postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres

JWT_SECRET=troque-por-um-segredo-de-no-minimo-32-caracteres
PORT=3001
WEB_ORIGIN=http://localhost:3000
